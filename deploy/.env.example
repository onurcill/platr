# ═══════════════════════════════════════════════════════════════════════════════
# Platr — Production Ortam Değişkenleri
# Kullanım: cp .env.example .env   →  .env'i düzenleyin
# ═══════════════════════════════════════════════════════════════════════════════

# ── ZORUNLU ──────────────────────────────────────────────────────────────────

# Uygulamanın domain adı (SSL sertifikası bu domain için alınır)
APP_DOMAIN=platr.sirketiniz.com

# Uygulamanın tam URL'i (e-posta davetlerinde kullanılır)
APP_URL=https://platr.sirketiniz.com

# JWT imzalama anahtarı — MUTLAKA değiştirin, güçlü tutun
# Üretmek için: openssl rand -base64 32
JWT_SECRET=BURAYA_openssl_rand_base64_32_CIKTISINIZI_YAZIN

# ── E-POSTA (İsteğe bağlı — workspace davet mailleri için) ───────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@sirketiniz.com
SMTP_PASSWORD=gmail-uygulama-sifresi
SMTP_FROM=noreply@sirketiniz.com

# Gmail için "Uygulama Şifresi" oluşturmanız gerekir:
# Google Hesabı → Güvenlik → 2 Adımlı Doğrulama → Uygulama şifreleri

# ── STRIPE (İsteğe bağlı — ücretli planlar için) ─────────────────────────────

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
