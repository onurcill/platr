# ── Production ortamı ─────────────────────────────────────────
PORT=8080
DB_PATH=/data/grpc-inspector.db

# Production'da güçlü bir secret kullan:
# openssl rand -base64 32
JWT_SECRET=CHANGE_ME_openssl_rand_base64_32

# SMTP — production maili
SMTP_HOST=smtp.sirket.com
SMTP_PORT=587
SMTP_USER=noreply@sirket.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@sirket.com

# Uygulamanın public URL'i
APP_URL=https://grpc-inspector.sirket.com
